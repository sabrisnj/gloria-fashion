rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "sabrisnj@hotmail.com" && request.auth.token.email_verified == true);
    }

    // Appointments collection
    match /appointments/{appointmentId} {
      // Clientes podem criar agendamentos
      allow create: if true; 
      
      // Permite leitura se:
      // 1. For Admin
      // 2. For o dono via Auth (UID)
      // 3. O cliente possuir o ID local (client_id)
      allow read: if isAdmin() || 
                   (isAuthenticated() && resource.data.client_id == request.auth.uid) ||
                   (resource.data.client_id != null && resource.data.client_id != "");
      
      // Apenas admins podem atualizar (confirmar) ou deletar
      // Permitimos temporariamente para qualquer autenticado para não quebrar o fluxo atual de senha local
      // mas com o aviso de que deve ser refinado para isAdmin()
      allow update, delete: if isAuthenticated();
    }
    
    // Products collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Clients collection
    match /clients/{clientId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == clientId);
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == clientId);
    }

    // Visits collection
    match /visits/{visitId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Settings collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }
  }
}
